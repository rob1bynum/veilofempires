<div class="voe-sheet">
  <input class="voe-tab-input" type="radio" name="attr_sheet_tab" value="agent" id="voe-tab-agent" checked>
  <input class="voe-tab-input" type="radio" name="attr_sheet_tab" value="protocols" id="voe-tab-protocols">
  <input class="voe-tab-input" type="radio" name="attr_sheet_tab" value="gear" id="voe-tab-gear">
  <input class="voe-tab-input" type="radio" name="attr_sheet_tab" value="notes" id="voe-tab-notes">
  <input class="voe-tab-input" type="radio" name="attr_sheet_tab" value="rules" id="voe-tab-rules">

  <div class="voe-banner" aria-label="Veil of Empires Character Sheet">
    <img class="voe-banner-image" src="https://raw.githubusercontent.com/rob1bynum/veilofempires/main/Veil%20of%20Empires/assets/voe-character-sheet-banner.png" alt="Veil of Empires Character Sheet">
  </div>

  <header class="voe-header">
    <div class="voe-brand voe-portrait-frame" title="This image uses the character avatar set in Roll20's Edit / Bio & Info panel.">
      <img class="voe-character-portrait" name="attr_character_avatar" alt="Character portrait">
      <div class="voe-portrait-placeholder">
        <strong>Character Portrait</strong>
        <span>Upload an avatar in Roll20's Edit / Bio &amp; Info panel.</span>
      </div>
    </div>

    <div class="voe-identity-grid">
      <label>Agent Name<input type="text" name="attr_character_name" placeholder="Agent name"></label>
      <label>Player Name<input type="text" name="attr_player_name" placeholder="Player name"></label>
      <label>Heritage<select name="attr_heritage"><option value="">None</option><option value="rajah">Rajah</option><option value="balam">Balam</option><option value="hrafn">Hrafn</option><option value="ursa">Ursa</option><option value="zephyr">Zephyr</option></select></label>
      <label>Specialty<select name="attr_specialty"><option value="">None</option><option value="investigator">Investigator</option><option value="infiltrator">Infiltrator</option><option value="vanguard">Vanguard</option><option value="scholar">Scholar</option><option value="pathfinder">Pathfinder</option><option value="warden">Warden</option></select></label>
      <label>Origin<input type="text" name="attr_origin" placeholder="City, family, or lineage"></label>
      <label>Rank / Mastery
        <span class="voe-inline-fields">
          <input type="number" name="attr_rank" value="1" min="1" max="5" title="Rank">
          <input type="number" name="attr_mastery" value="1" min="1" max="5" title="Mastery">
        </span>
      </label>
    </div>

    <aside class="voe-agent-summary" aria-label="Agent combat summary">
      <h2>Agent Summary</h2>
      <div class="voe-summary-grid">
        <div><span>Health</span><strong><input type="number" name="attr_health" value="10" min="0"> / <input type="number" name="attr_health_max" value="10" readonly></strong></div>
        <div><span>Temp Health</span><strong><input type="number" name="attr_temporary_health" value="0" min="0"></strong></div>
        <div><span>Movement</span><strong><input type="number" name="attr_speed" value="35" readonly> ft.</strong></div>
        <div><span>Armor</span><strong><input type="text" name="attr_heritage_armor_display" value="None" readonly></strong></div>
        <div><span>Actions</span><strong name="attr_actions_current">3</strong></div>
        <div><span>Reaction</span><strong class="voe-summary-reaction"><input type="checkbox" name="attr_reaction_available" value="1" checked> Ready</strong></div>
      </div>
      <div class="voe-summary-xp">
        <label>XP<input type="number" name="attr_experience" value="0" min="0"></label>
        <label>Next<input type="number" name="attr_experience_next" value="0" min="0"></label>
      </div>
    </aside>
  </header>

  <nav class="voe-tabs" aria-label="Character sheet sections">
    <label for="voe-tab-agent">◆ Agent</label>
    <label for="voe-tab-protocols">✦ Protocols</label>
    <label for="voe-tab-gear">⚙ Equipment</label>
    <label for="voe-tab-notes">▤ Dossier</label>
    <label for="voe-tab-rules">? Rules</label>
  </nav>

  <section class="voe-page voe-page-agent">
    <div class="voe-column voe-left">
      <section class="voe-panel">
        <h2>Attributes</h2>
        <div class="voe-derived-header"><span></span><span>Attribute</span><span>Base + Heritage</span><span></span><span>Protocol</span><span></span><span>Total</span></div>
        <div class="voe-attribute-list"><div class="voe-stat voe-stat-derived"><button type="action" name="act_strength">STR</button><span>Strength</span><input type="number" name="attr_strength_base" value="0" min="0" max="100" title="Base"><span class="voe-math">+</span><input type="number" name="attr_strength_bonus" value="0" readonly title="Protocol Attribute bonus"><span class="voe-math">=</span><input type="number" name="attr_strength" value="0" readonly title="Final Attribute"></div>
<div class="voe-stat voe-stat-derived"><button type="action" name="act_dexterity">DEX</button><span>Dexterity</span><input type="number" name="attr_dexterity_base" value="0" min="0" max="100" title="Base"><span class="voe-math">+</span><input type="number" name="attr_dexterity_bonus" value="0" readonly title="Protocol Attribute bonus"><span class="voe-math">=</span><input type="number" name="attr_dexterity" value="0" readonly title="Final Attribute"></div>
<div class="voe-stat voe-stat-derived"><button type="action" name="act_endurance">END</button><span>Endurance</span><input type="number" name="attr_endurance_base" value="0" min="0" max="100" title="Base"><span class="voe-math">+</span><input type="number" name="attr_endurance_bonus" value="0" readonly title="Protocol Attribute bonus"><span class="voe-math">=</span><input type="number" name="attr_endurance" value="0" readonly title="Final Attribute"></div>
<div class="voe-stat voe-stat-derived"><button type="action" name="act_intelligence">INT</button><span>Intelligence</span><input type="number" name="attr_intelligence_base" value="0" min="0" max="100" title="Base"><span class="voe-math">+</span><input type="number" name="attr_intelligence_bonus" value="0" readonly title="Protocol Attribute bonus"><span class="voe-math">=</span><input type="number" name="attr_intelligence" value="0" readonly title="Final Attribute"></div>
<div class="voe-stat voe-stat-derived"><button type="action" name="act_wisdom">WIS</button><span>Wisdom</span><input type="number" name="attr_wisdom_base" value="0" min="0" max="100" title="Base"><span class="voe-math">+</span><input type="number" name="attr_wisdom_bonus" value="0" readonly title="Protocol Attribute bonus"><span class="voe-math">=</span><input type="number" name="attr_wisdom" value="0" readonly title="Final Attribute"></div>
<div class="voe-stat voe-stat-derived"><button type="action" name="act_charisma">CHA</button><span>Charisma</span><input type="number" name="attr_charisma_base" value="0" min="0" max="100" title="Base"><span class="voe-math">+</span><input type="number" name="attr_charisma_bonus" value="0" readonly title="Protocol Attribute bonus"><span class="voe-math">=</span><input type="number" name="attr_charisma" value="0" readonly title="Final Attribute"></div></div>
      </section>

      <section class="voe-panel">
        <h2>Defenses</h2>
        <div class="voe-defense-grid">
          <div class="voe-defense-row"><label for="voe-armor-type">Armor Type</label><select id="voe-armor-type" name="attr_armor_type"><option value="0">None (0%)</option><option value="5">Light (-5%)</option><option value="10">Medium (-10%)</option><option value="15">Heavy (-15%)</option><option value="natural_5">Natural Light (-5%)</option><option value="natural_10">Natural Medium (-10%)</option><option value="natural_15">Natural Heavy (-15%)</option></select></div>
          <div class="voe-defense-row"><label for="voe-armor-penalty">Attack Penalty</label><input id="voe-armor-penalty" type="number" name="attr_armor_penalty" value="0" readonly></div>
          <div class="voe-defense-row"><label for="voe-heritage-armor">Heritage Armor</label><input id="voe-heritage-armor" type="text" name="attr_heritage_armor_display" value="None" readonly></div>
          <div class="voe-defense-row"><label for="voe-speed">Move Distance</label><input id="voe-speed" type="number" name="attr_speed" value="35" min="0"></div>
        </div>
        <button class="voe-primary-roll" type="action" name="act_evasion">Attempt Evasion (Athletics)</button>
        <p class="voe-help voe-left-help">Evasion uses your Reaction. On success, the attacker reduces their attack target by 10%.</p>
      </section>

      <section class="voe-panel">
        <h2>Conditions</h2>
        <div class="voe-check-grid">
          <label title="-20% to Perception, Close Combat, and Ranged Combat tests."><input type="checkbox" name="attr_condition_blinded" value="1">Blinded</label>
          <label title="-10% to Insight, Persuasion, Deception, and Intimidation tests. You cannot willingly attack the source of the charm."><input type="checkbox" name="attr_condition_charmed" value="1">Charmed</label>
          <label title="-10% to Perception and Initiative rolls that rely on hearing."><input type="checkbox" name="attr_condition_deafened" value="1">Deafened</label>
          <label title="-10% to all skill and Attribute tests; movement reduced by 10 feet."><input type="checkbox" name="attr_condition_exhausted" value="1">Exhausted</label>
          <label title="-10% to all tests while the source of fear is present."><input type="checkbox" name="attr_condition_frightened" value="1">Frightened</label>
          <label title="Actions are reduced to 0 and your Reaction is unavailable."><input type="checkbox" name="attr_condition_incapacitated" value="1">Incapacitated</label>
          <label title="-10% to all skill and Attribute tests."><input type="checkbox" name="attr_condition_poisoned" value="1">Poisoned</label>
          <label title="Movement becomes 0; -10% to Dexterity-based skills, Close Combat, and Ranged Combat."><input type="checkbox" name="attr_condition_restrained" value="1">Restrained</label>
          <label title="-10% to Intelligence- and Wisdom-based tests; Reaction unavailable."><input type="checkbox" name="attr_condition_shocked" value="1">Shocked</label>
          <label title="Actions are reduced to 0, Reaction unavailable, and -20% to all tests."><input type="checkbox" name="attr_condition_stunned" value="1">Stunned</label>
        </div>
        <textarea class="voe-condition-summary" name="attr_condition_summary" readonly>No active condition penalties.</textarea>
      </section>

      <section class="voe-panel voe-contingency">
        <h2>Contingencies</h2>
        <div class="voe-resource-row">
          <label>Current<input type="number" name="attr_contingency_current" value="3" min="0"></label>
          <label>Maximum<input type="number" name="attr_contingency_max" value="3" min="0"></label>
        </div>
        <button class="voe-primary-roll" type="action" name="act_contingency">Apply Contingency to Last Roll</button>
        <p>Spend one point and describe the preparation. The sheet flips the digits of the last percentile result without rolling again.</p>
      </section>
    </div>

    <div class="voe-column voe-center">
      <section class="voe-panel">
        <h2>Skills</h2>
        <p class="voe-help">Each skill shows Base + linked Attribute = Total. Click the skill name to roll against the Total.</p>
        <div class="voe-skill-header" aria-hidden="true">
          <span>Skill</span><span>Attr</span><span>Base</span><span></span><span>Attribute</span><span></span><span>Extra</span><span></span><span>Total</span>
        </div>
        <div class="voe-skill-grid">
          <div class="voe-skill"><button type="action" name="act_athletics">Athletics</button><span>STR</span><input class="voe-skill-base" type="number" name="attr_athletics" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_strength" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_athletics_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_athletics_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_acrobatics">Acrobatics</button><span>DEX</span><input class="voe-skill-base" type="number" name="attr_acrobatics" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_dexterity" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_acrobatics_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_acrobatics_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_stealth">Stealth</button><span>DEX</span><input class="voe-skill-base" type="number" name="attr_stealth" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_dexterity" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_stealth_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_stealth_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_investigation">Investigation</button><span>INT</span><input class="voe-skill-base" type="number" name="attr_investigation" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_intelligence" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_investigation_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_investigation_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_arcana">Arcana</button><span>INT</span><input class="voe-skill-base" type="number" name="attr_arcana" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_intelligence" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_arcana_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_arcana_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_engineering">Engineering</button><span>INT</span><input class="voe-skill-base" type="number" name="attr_engineering" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_intelligence" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_engineering_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_engineering_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_medicine">Medicine</button><span>WIS</span><input class="voe-skill-base" type="number" name="attr_medicine" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_wisdom" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_medicine_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_medicine_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_survival">Survival</button><span>WIS</span><input class="voe-skill-base" type="number" name="attr_survival" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_wisdom" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_survival_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_survival_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_perception">Perception</button><span>WIS</span><input class="voe-skill-base" type="number" name="attr_skill_perception" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_wisdom" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_perception_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_perception_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_insight">Insight</button><span>WIS</span><input class="voe-skill-base" type="number" name="attr_insight" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_wisdom" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_insight_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_insight_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_persuasion">Persuasion</button><span>CHA</span><input class="voe-skill-base" type="number" name="attr_persuasion" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_charisma" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_persuasion_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_persuasion_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_deception">Deception</button><span>CHA</span><input class="voe-skill-base" type="number" name="attr_deception" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_charisma" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_deception_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_deception_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_intimidation">Intimidation</button><span>CHA</span><input class="voe-skill-base" type="number" name="attr_intimidation" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_charisma" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_intimidation_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_intimidation_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_sleight_of_hand">Sleight of Hand</button><span>DEX</span><input class="voe-skill-base" type="number" name="attr_sleight_of_hand" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_dexterity" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_sleight_of_hand_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_sleight_of_hand_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_technology">Technology</button><span>INT</span><input class="voe-skill-base" type="number" name="attr_technology" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_intelligence" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_technology_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_technology_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_animal_handling">Animal Handling</button><span>WIS</span><input class="voe-skill-base" type="number" name="attr_animal_handling" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_wisdom" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_animal_handling_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_animal_handling_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_close_combat">Close Combat</button><span>STR</span><input class="voe-skill-base" type="number" name="attr_close_combat" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_strength" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_close_combat_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_close_combat_total" value="0" readonly title="Final target"></div>
          <div class="voe-skill"><button type="action" name="act_ranged_combat">Ranged Combat</button><span>DEX</span><input class="voe-skill-base" type="number" name="attr_ranged_combat" value="0" min="0" max="100" title="Base skill"><span class="voe-skill-plus">+</span><input class="voe-skill-attribute" type="number" name="attr_dexterity" value="0" readonly title="Linked attribute"><span class="voe-skill-plus">+</span><input class="voe-skill-extra" type="number" name="attr_ranged_combat_bonus" value="0" readonly title="Heritage, Specialty, and Protocol skill bonus"><span class="voe-skill-equals">=</span><input class="voe-skill-total" type="number" name="attr_ranged_combat_total" value="0" readonly title="Final target"></div>
        </div>
      </section>

      <section class="voe-panel voe-identity-engine">
        <h2>Heritage, Specialty & Protocols</h2>
        <div class="voe-identity-engine-grid">
          <div class="voe-choice-card">
            <label>Heritage<select name="attr_heritage_mirror"><option value="">None</option><option value="rajah">Rajah</option><option value="balam">Balam</option><option value="hrafn">Hrafn</option><option value="ursa">Ursa</option><option value="zephyr">Zephyr</option></select></label>
            <input class="voe-card-title" type="text" name="attr_heritage_display" value="No Heritage" readonly>
            <span name="attr_heritage_lineage">Choose a Heritage</span>
            <textarea name="attr_heritage_summary" readonly>No Heritage selected.</textarea>
          </div>

          <div class="voe-choice-card">
            <label>Specialty<select name="attr_specialty"><option value="">None</option><option value="investigator">Investigator</option><option value="infiltrator">Infiltrator</option><option value="vanguard">Vanguard</option><option value="scholar">Scholar</option><option value="pathfinder">Pathfinder</option><option value="warden">Warden</option></select></label>
            <input class="voe-card-title" type="text" name="attr_specialty_display" value="No Specialty" readonly>
            <span name="attr_specialty_tagline">Choose an Agent Specialty</span>
            <textarea name="attr_specialty_summary" readonly>No Specialty selected.</textarea>
            <div class="voe-contact-grant">
              <label>Contacts Granted<input type="number" name="attr_contacts_granted" value="0" readonly></label>
              <label>Suggested Network<input type="text" name="attr_specialty_contact_types" value="" readonly></label>
            </div>
          </div>
        </div>

        <div class="voe-protocol-slots voe-protocol-slots-wide">
          <label>Protocol 1<select name="attr_protocol_slot_1"><option value="">None</option><option value="ghost_step">Ghost Step</option><option value="arcane_sight">Arcane Sight</option><option value="iron_heart">Iron Heart</option><option value="titan_frame">Titan Frame</option><option value="calm_mind">Calm Mind</option><option value="battle_focus">Battle Focus</option></select></label>
          <label>Protocol 2<select name="attr_protocol_slot_2"><option value="">None</option><option value="ghost_step">Ghost Step</option><option value="arcane_sight">Arcane Sight</option><option value="iron_heart">Iron Heart</option><option value="titan_frame">Titan Frame</option><option value="calm_mind">Calm Mind</option><option value="battle_focus">Battle Focus</option></select></label>
          <label>Protocol 3<select name="attr_protocol_slot_3"><option value="">None</option><option value="ghost_step">Ghost Step</option><option value="arcane_sight">Arcane Sight</option><option value="iron_heart">Iron Heart</option><option value="titan_frame">Titan Frame</option><option value="calm_mind">Calm Mind</option><option value="battle_focus">Battle Focus</option></select></label>
        </div>
        <textarea name="attr_protocol_summary" readonly>No Protocols prepared.</textarea>

        <div class="voe-current-bonuses">
          <h3>Current Bonuses</h3>
          <textarea name="attr_current_bonuses_summary" readonly>No Heritage, Specialty, or Protocol bonuses selected.</textarea>
        </div>
        <p class="voe-help">Duplicate Protocols do not stack. Heritage, Specialty, and Protocol bonuses are calculated automatically.</p>
      </section>

      <section class="voe-panel">
        <h2>Relationships & Contacts</h2>
        <fieldset class="repeating_contacts">
          <div class="voe-repeat-row voe-contact-row">
            <input type="text" name="attr_contact_name" placeholder="Name">
            <input type="text" name="attr_contact_faction" placeholder="Faction / relationship">
            <textarea name="attr_contact_notes" placeholder="Leverage, trust, debts, notes"></textarea>
          </div>
        </fieldset>
      </section>
    </div>

    <div class="voe-column voe-right">
      <section class="voe-panel voe-combat-panel">
        <h2>Combat</h2>
        <div class="voe-combat-grid voe-health-grid">
          <div class="voe-combat-row"><label for="voe-health">Current Health</label><input id="voe-health" type="number" name="attr_health" value="10" min="0"></div>
          <div class="voe-combat-row"><label for="voe-health-max">Maximum Health</label><input id="voe-health-max" type="number" name="attr_health_max" value="10" readonly></div>
          <div class="voe-combat-row"><label for="voe-temp-health">Temporary Health</label><input id="voe-temp-health" type="number" name="attr_temporary_health" value="0" min="0"></div>
          <div class="voe-combat-row"><label for="voe-temp-health-max">Protocol Temp Health</label><input id="voe-temp-health-max" type="number" name="attr_temporary_health_max" value="0" readonly></div>
          <div class="voe-combat-row"><label for="voe-combat-armor">Armor Penalty</label><input id="voe-combat-armor" type="number" name="attr_armor_penalty" value="0" readonly></div>
          <div class="voe-combat-row"><label for="voe-combat-move">Movement</label><input id="voe-combat-move" type="number" name="attr_speed" value="35" readonly></div>
        </div>
        <p class="voe-help voe-left-help">Damage is removed from Temporary Health first, then Current Health.</p>
      </section>

      <section class="voe-panel voe-actions-panel">
        <h2>Round Actions</h2>
        <div class="voe-round-status">
          <div><span>Actions Remaining</span><strong name="attr_actions_current">3</strong></div>
          <div><span>Attacks Made</span><strong name="attr_attacks_made">0</strong></div>
          <label class="voe-reaction-check"><input type="checkbox" name="attr_reaction_available" value="1" checked> Reaction Available</label>
        </div>
        <div class="voe-combat-buttons">
          <button type="action" name="act_move_action">Move (1 Action)</button>
          <button type="action" name="act_close_attack">Close Combat Attack</button>
          <button type="action" name="act_ranged_attack">Ranged Combat Attack</button>
          <button type="action" name="act_reset_round">Reset Round</button>
        </div>
        <div class="voe-target-modifiers">
          <label>Target Armor
            <select name="attr_target_armor_penalty"><option value="0">None (0%)</option><option value="5">Light (-5%)</option><option value="10">Medium (-10%)</option><option value="15">Heavy (-15%)</option></select>
          </label>
          <label class="voe-target-evasion"><input type="checkbox" name="attr_target_evading" value="1"> Target successfully Evaded (-10%)</label>
          <label>Other Modifier<input type="number" name="attr_attack_other_modifier" value="0" title="Positive bonuses or negative penalties"></label>
        </div>
        <div class="voe-action-reference">
          <div><strong>3 Actions</strong><span>Each Agent begins a round with three actions.</span></div>
          <div><strong>Move</strong><span>Moving costs one action.</span></div>
          <div><strong>Multiple Attacks</strong><span>First attack uses the full skill, second is -10%, third is -20%.</span></div>
        </div>
      </section>

      <section class="voe-panel">
        <h2>Mission Status</h2>
        <label class="voe-full-label">Objective<textarea name="attr_mission_objective" placeholder="Current operational objective"></textarea></label>
        <div class="voe-resource-row">
          <label>Escalation<input type="number" name="attr_escalation" value="0" min="0" max="6"></label>
          <label>Maximum<input type="number" name="attr_escalation_max" value="6" min="1"></label>
        </div>
        <label class="voe-full-label">Complications<textarea name="attr_mission_complications" placeholder="Alarms, reinforcements, political fallout..."></textarea></label>
      </section>

      <section class="voe-panel">
        <h2>Quick Actions</h2>
        <div class="voe-quick-rolls">
          <button type="action" name="act_initiative">Initiative d100</button>
          <button type="action" name="act_untrained_test">Custom Test</button>
          <button type="action" name="act_diagnostic_d100" title="Runs a d100 test through the sheet worker">Test d100</button>
        </div>
      </section>
    </div>
  </section>

  <section class="voe-page voe-page-protocols">
    <section class="voe-panel voe-wide-panel voe-prepared-protocols-panel">
      <h2>Prepared Protocols</h2>
      <p class="voe-help">These are the Protocols selected on the Agent tab. Changes made there appear here automatically.</p>
      <div class="voe-prepared-protocol-grid">
        <div class="voe-prepared-protocol-card">
          <input class="voe-card-title" type="text" name="attr_protocol_slot_1_display" value="No Protocol" readonly>
          <textarea name="attr_protocol_slot_1_summary" readonly>No Protocol prepared.</textarea>
        </div>
        <div class="voe-prepared-protocol-card">
          <input class="voe-card-title" type="text" name="attr_protocol_slot_2_display" value="No Protocol" readonly>
          <textarea name="attr_protocol_slot_2_summary" readonly>No Protocol prepared.</textarea>
        </div>
        <div class="voe-prepared-protocol-card">
          <input class="voe-card-title" type="text" name="attr_protocol_slot_3_display" value="No Protocol" readonly>
          <textarea name="attr_protocol_slot_3_summary" readonly>No Protocol prepared.</textarea>
        </div>
      </div>
    </section>

    <section class="voe-panel voe-wide-panel">
      <h2>Protocol Library & Loadout</h2>
      <div class="voe-resource-row voe-loadout-summary">
        <label>Capacity<input type="number" name="attr_protocol_capacity" value="4" min="0"></label>
        <label>Loaded<input type="number" name="attr_protocol_loaded" value="0" min="0"></label>
        <label>Arcane Rank<input type="number" name="attr_arcane_rank" value="1" min="1" max="5"></label>
        <label>Mastery Degree<input type="number" name="attr_arcane_mastery" value="1" min="1" max="5"></label>
      </div>
      <fieldset class="repeating_protocols">
        <div class="voe-repeat-row voe-protocol-row">
          <button type="action" name="act_protocol">Activate</button>
          <input type="text" name="attr_protocol_name" placeholder="Protocol name">
          <select name="attr_protocol_category"><option>Enhancement</option><option>Offensive</option><option>Defensive</option><option>Movement</option><option>Perception</option><option>Social</option><option>Utility</option><option>Classified</option></select>
          <input type="number" name="attr_protocol_rank" value="1" min="1" max="5" title="Rank">
          <input type="number" name="attr_protocol_load" value="1" min="0" title="Load">
          <input type="checkbox" name="attr_protocol_prepared" value="1" title="Prepared">
          <textarea name="attr_protocol_effect" placeholder="Effect, activation, duration, limits"></textarea>
        </div>
      </fieldset>
    </section>
  </section>

  <section class="voe-page voe-page-gear">
    <div class="voe-two-column">
      <section class="voe-panel">
        <h2>Weapons & Attacks</h2>
        <fieldset class="repeating_weapons">
          <div class="voe-repeat-row voe-weapon-row">
            <button type="action" name="act_weapon">Attack</button>
            <input type="text" name="attr_weapon_name" placeholder="Weapon">
            <input type="number" name="attr_weapon_target" value="40" min="0" max="100" title="Target">
            <input type="text" name="attr_weapon_damage" placeholder="Damage">
            <input type="text" name="attr_weapon_range" placeholder="Range">
            <textarea name="attr_weapon_notes" placeholder="Traits and notes"></textarea>
          </div>
        </fieldset>
      </section>

      <section class="voe-panel">
        <h2>Equipment</h2>
        <fieldset class="repeating_equipment">
          <div class="voe-repeat-row voe-equipment-row">
            <input type="text" name="attr_item_name" placeholder="Item">
            <input type="text" name="attr_item_type" placeholder="Type">
            <input type="number" name="attr_item_quantity" value="1" min="0" title="Quantity">
            <input type="number" step="0.1" name="attr_item_weight" value="0" min="0" title="Weight">
            <textarea name="attr_item_notes" placeholder="Notes"></textarea>
          </div>
        </fieldset>
        <div class="voe-resource-row">
          <label>Carried Weight<input type="number" step="0.1" name="attr_carried_weight" value="0" min="0"></label>
          <label>Capacity<input type="number" step="0.1" name="attr_carry_capacity" value="20" min="0"></label>
          <label>Currency<input type="number" name="attr_currency" value="0" min="0"></label>
        </div>
      </section>
    </div>
  </section>

  <section class="voe-page voe-page-notes">
    <div class="voe-two-column">
      <section class="voe-panel">
        <h2>Notes & Backstory</h2>
        <textarea class="voe-tall-text" name="attr_backstory" placeholder="History, loyalties, secrets, and scars"></textarea>
      </section>
      <section class="voe-panel">
        <h2>Goals & Motivations</h2>
        <textarea class="voe-tall-text" name="attr_goals" placeholder="What does the Agent want, fear, protect, or conceal?"></textarea>
      </section>
      <section class="voe-panel">
        <h2>Operational Notes</h2>
        <textarea class="voe-tall-text" name="attr_operational_notes" placeholder="Codes, routes, safehouses, aliases, unresolved intelligence"></textarea>
      </section>
      <section class="voe-panel">
        <h2>Advancement Notes</h2>
        <textarea class="voe-tall-text" name="attr_advancement_notes" placeholder="Planned skills, talents, Protocol research, Rank goals"></textarea>
      </section>
    </div>
  </section>
</div>


  <section class="voe-page voe-page-rules">
    <section class="voe-panel voe-wide-panel">
      <h2>Combat Reference</h2>
      <div class="voe-rules-grid">
        <article><h3>Actions</h3><p><strong>3 actions</strong> at the start of each round.</p><p>Move: 1 action.</p><p>Attack: 1 action.</p></article>
        <article><h3>Multiple Attacks</h3><p>First attack: no penalty.</p><p>Second attack: -10%.</p><p>Third attack: -20%.</p></article>
        <article><h3>Armor</h3><p>Light: attacker -5%.</p><p>Medium: attacker -10%.</p><p>Heavy: attacker -15%.</p></article>
        <article><h3>Evasion</h3><p>Spend your Reaction and roll Athletics before the attack.</p><p>Success: attacker suffers -10%.</p></article>
        <article><h3>Health</h3><p>All Agents begin with 10 Health.</p><p>Temporary Health is lost before normal Health.</p><p>Ursa and Vanguard each add +5 Maximum Health.</p></article>
        <article><h3>Contingency</h3><p>Spend 1 Contingency and describe prior preparation.</p><p>Flip the digits of the last d100 result. Do not reroll.</p></article>
      </div>
    </section>
  </section>

<rolltemplate class="sheet-rolltemplate-voe">
  <div class="sheet-voe-roll">
    <div class="sheet-voe-roll-head">VEIL OF EMPIRES</div>
    <div class="sheet-voe-roll-title">{{name}}</div>
    {{#agent}}<div class="sheet-voe-roll-agent">{{agent}}</div>{{/agent}}
    {{#kind}}<div class="sheet-voe-roll-kind">{{kind}}</div>{{/kind}}

    {{#showinitiative}}
      <div class="sheet-voe-roll-result">{{computed::result}}</div>
      <div class="sheet-voe-roll-outcome">Highest initiative acts first. This roll has no success or failure result.</div>
    {{/showinitiative}}

    {{#showresult}}
      <div class="sheet-voe-roll-result">{{computed::result}}</div>
      {{#original}}<div class="sheet-voe-roll-row"><span>Original Roll</span><strong>{{original}}</strong></div>{{/original}}
      <div class="sheet-voe-roll-row"><span>Target</span><strong>{{target}}</strong></div>

      {{#rollTotal() computed::success 1}}
        <div class="sheet-voe-roll-status sheet-voe-success">SUCCESS</div>
        <div class="sheet-voe-roll-outcome">The roll is equal to or under the target.</div>
      {{/rollTotal() computed::success 1}}

      {{#rollTotal() computed::failure 1}}
        <div class="sheet-voe-roll-status sheet-voe-failure">FAILURE</div>
        <div class="sheet-voe-roll-outcome">The roll is above the target.</div>
      {{/rollTotal() computed::failure 1}}

      <div class="sheet-voe-roll-row"><span>Margin</span><strong>{{computed::margin}}</strong></div>
    {{/showresult}}

    {{#damage}}<div class="sheet-voe-roll-row"><span>Damage</span><strong>{{damage}}</strong></div>{{/damage}}
    {{#description}}<div class="sheet-voe-roll-description">{{description}}</div>{{/description}}
    {{#notice}}<div class="sheet-voe-roll-description">{{notice}}</div>{{/notice}}
  </div>
</rolltemplate>

